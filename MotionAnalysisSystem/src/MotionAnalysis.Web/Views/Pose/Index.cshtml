@model MotionAnalysis.Web.Models.VideoAnalyzeViewModel

@{
    ViewData["Title"] = "動作分析";
    var pendingFull = string.Equals(Model.ModelComparisonStatus, "pending_full", StringComparison.OrdinalIgnoreCase);
    var compareCompleted = string.Equals(Model.ModelComparisonStatus, "completed", StringComparison.OrdinalIgnoreCase);
    var showLite = !string.IsNullOrWhiteSpace(Model.SkeletonLiteVideoUrl)
        || !string.IsNullOrWhiteSpace(Model.TrajectoryLiteVideoUrl)
        || !string.IsNullOrWhiteSpace(Model.SkeletonVideoUrl)
        || !string.IsNullOrWhiteSpace(Model.TrajectoryVideoUrl);
}

<h2>動作姿態節點分析</h2>
<p class="text-muted">輸出關節座標、角度與軌跡等客觀量測資料，不評價動作品質。</p>

<form asp-controller="Pose"
      asp-action="Index"
      method="post"
      enctype="multipart/form-data"
      class="mt-3"
      id="analyzeForm">

    <div class="mb-3">
        <label class="form-label" asp-for="VideoFile"></label>
        <input asp-for="VideoFile" type="file" class="form-control" accept="video/*" />
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">動作</label>
            <select id="movementSelect" class="form-select" name="movementSelect">
                @foreach (var m in Model.AvailableMovements)
                {
                    var selected = Model.SportType == m.SportType && Model.MovementType == m.MovementType;
                    if (selected)
                    {
                        <option value="@($"{m.SportType}|{m.MovementType}")" selected>@m.Label</option>
                    }
                    else
                    {
                        <option value="@($"{m.SportType}|{m.MovementType}")">@m.Label</option>
                    }
                }
            </select>
            <input type="hidden" asp-for="SportType" id="SportType" />
            <input type="hidden" asp-for="MovementType" id="MovementType" />
        </div>
        <div class="col-md-3 mb-3">
            <label class="form-label" asp-for="CameraView"></label>
            <select asp-for="CameraView" class="form-select">
                @foreach (var v in VideoAnalyzeViewModel.CameraViews)
                {
                    if (Model.CameraView == v.Value)
                    {
                        <option value="@v.Value" selected>@v.Label</option>
                    }
                    else
                    {
                        <option value="@v.Value">@v.Label</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3 mb-3">
            <label class="form-label" asp-for="DominantSide"></label>
            <select asp-for="DominantSide" class="form-select">
                @if (Model.DominantSide == "left")
                {
                    <option value="right">右側</option>
                    <option value="left" selected>左側</option>
                }
                else
                {
                    <option value="right" selected>右側</option>
                    <option value="left">左側</option>
                }
            </select>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3 mb-3">
            <label class="form-label" asp-for="FrameInterval"></label>
            <input asp-for="FrameInterval" type="number" min="1" max="30" class="form-control" />
            <div class="form-text">每 N 幀分析一次（1 = 全幀）</div>
        </div>
        <div class="col-md-3 mb-3 form-check align-self-center">
            <input asp-for="GenerateSkeletonVideo" class="form-check-input" />
            <label class="form-check-label" asp-for="GenerateSkeletonVideo"></label>
        </div>
        <div class="col-md-3 mb-3 form-check align-self-center">
            <input asp-for="GenerateTrajectoryVideo" class="form-check-input" />
            <label class="form-check-label" asp-for="GenerateTrajectoryVideo"></label>
        </div>
        <div class="col-md-3 mb-3 form-check align-self-center">
            <input asp-for="BrowserPlayableVideo" class="form-check-input" />
            <label class="form-check-label" asp-for="BrowserPlayableVideo"></label>
            <div class="form-text">未勾選僅提供下載連結（較快）</div>
        </div>
    </div>

    <div class="mb-3 form-check">
        <input asp-for="CompareWithFull" class="form-check-input" />
        <label class="form-check-label" asp-for="CompareWithFull"></label>
        <div class="form-text">先顯示 Lite 結果，再於背景跑 Full 並計算差異百分比。</div>
    </div>

    <button type="submit" class="btn btn-primary" id="analyzeSubmitBtn">
        開始分析
    </button>
</form>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger mt-3">
        @Model.ErrorMessage
    </div>
}

@if (Model.WarningMessages.Count > 0)
{
    <div class="alert alert-warning mt-3">
        <strong>資料品質警告</strong>
        <ul class="mb-0 mt-2">
            @foreach (var w in Model.WarningMessages)
            {
                <li>@w</li>
            }
        </ul>
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.AnalysisId))
{
    <p class="mt-3 text-muted">分析編號：<span id="analysisIdText">@Model.AnalysisId</span></p>
}

<div id="compareBanner" class="mt-3" style="@(pendingFull || compareCompleted ? "" : "display:none;")">
    @if (pendingFull)
    {
        <div class="alert alert-info mb-0" id="comparePendingAlert">
            Lite 分析已完成。正在以 Full 模型進行對照分析，請稍候…
        </div>
    }
    <div class="alert alert-secondary mb-0" id="compareResultAlert" style="@(compareCompleted ? "" : "display:none;")">
        <strong>Lite 相對 Full 差異：</strong>
        <span id="overallDiffPercentText">
            @(Model.OverallDiffPercent.HasValue ? $"{Model.OverallDiffPercent.Value:0.##}%" : "—")
        </span>
        <div class="small text-muted mt-1" id="compareDescText">
            @(Model.ModelComparisonDescription ?? "以 Full 為基準：可比關節之平均 (|Lite−Full| / Full身體尺度) × 100%。")
        </div>
    </div>
</div>

@if (showLite)
{
    <div class="mt-4">
        <h3>Lite 模型</h3>
        <div class="row">
            @{
                var liteSk = Model.SkeletonLiteVideoUrl ?? Model.SkeletonVideoUrl;
                var liteTr = Model.TrajectoryLiteVideoUrl ?? Model.TrajectoryVideoUrl;
            }
            @if (!string.IsNullOrWhiteSpace(liteSk))
            {
                <div class="col-md-6 mb-3">
                    <h5>骨架標註影片（含關節角度）</h5>
                    @if (Model.BrowserPlayableVideo)
                    {
                        <video controls playsinline style="max-width: 100%; background: #000;">
                            <source src="@liteSk" type="video/mp4" />
                        </video>
                    }
                    <div><a href="@liteSk" target="_blank" rel="noopener">開啟／下載</a></div>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(liteTr))
            {
                <div class="col-md-6 mb-3">
                    <h5>關節軌跡影片</h5>
                    @if (Model.BrowserPlayableVideo)
                    {
                        <video controls playsinline style="max-width: 100%; background: #000;">
                            <source src="@liteTr" type="video/mp4" />
                        </video>
                    }
                    <div><a href="@liteTr" target="_blank" rel="noopener">開啟／下載</a></div>
                </div>
            }
        </div>
    </div>
}

<div id="fullResultSection" class="mt-4" style="@(compareCompleted ? "" : "display:none;")">
    <h3>Full 模型（對照）</h3>
    <div class="row">
        <div class="col-md-6 mb-3" id="fullSkeletonBlock" style="@(!string.IsNullOrWhiteSpace(Model.SkeletonFullVideoUrl) ? "" : "display:none;")">
            <h5>骨架標註影片（含關節角度）</h5>
            <div id="fullSkeletonPlayer">
                @if (Model.BrowserPlayableVideo && !string.IsNullOrWhiteSpace(Model.SkeletonFullVideoUrl))
                {
                    <video controls playsinline style="max-width: 100%; background: #000;">
                        <source src="@Model.SkeletonFullVideoUrl" type="video/mp4" />
                    </video>
                }
            </div>
            <div><a id="fullSkeletonLink" href="@(Model.SkeletonFullVideoUrl ?? "#")" target="_blank" rel="noopener">開啟／下載</a></div>
        </div>
        <div class="col-md-6 mb-3" id="fullTrajectoryBlock" style="@(!string.IsNullOrWhiteSpace(Model.TrajectoryFullVideoUrl) ? "" : "display:none;")">
            <h5>關節軌跡影片</h5>
            <div id="fullTrajectoryPlayer">
                @if (Model.BrowserPlayableVideo && !string.IsNullOrWhiteSpace(Model.TrajectoryFullVideoUrl))
                {
                    <video controls playsinline style="max-width: 100%; background: #000;">
                        <source src="@Model.TrajectoryFullVideoUrl" type="video/mp4" />
                    </video>
                }
            </div>
            <div><a id="fullTrajectoryLink" href="@(Model.TrajectoryFullVideoUrl ?? "#")" target="_blank" rel="noopener">開啟／下載</a></div>
        </div>
    </div>
</div>

@{
    var liteJsonUrl = Model.RawLiteJsonUrl ?? Model.RawJsonUrl;
    var fullJsonUrl = Model.RawFullJsonUrl;
}
@if (!string.IsNullOrWhiteSpace(liteJsonUrl) || !string.IsNullOrWhiteSpace(fullJsonUrl))
{
    <div class="mt-3 d-flex flex-wrap gap-2" id="jsonDownloadButtons">
        @if (!string.IsNullOrWhiteSpace(liteJsonUrl))
        {
            <a id="rawLiteJsonLink"
               class="btn btn-outline-secondary btn-sm"
               href="@liteJsonUrl"
               target="_blank"
               rel="noopener">下載 Lite JSON</a>
        }
        else
        {
            <a id="rawLiteJsonLink"
               class="btn btn-outline-secondary btn-sm"
               href="#"
               target="_blank"
               rel="noopener"
               style="display:none;">下載 Lite JSON</a>
        }
        <a id="rawFullJsonLink"
           class="btn btn-outline-secondary btn-sm"
           href="@(fullJsonUrl ?? "#")"
           target="_blank"
           rel="noopener"
           style="@(string.IsNullOrWhiteSpace(fullJsonUrl) ? "display:none;" : "")">下載 Full JSON</a>
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.AnalysisJson))
{
    <details class="mt-4">
        <summary><h3 style="display:inline;">分析結果 JSON</h3></summary>
        <pre id="analysisJsonPre" style="white-space: pre-wrap; background: #f5f5f5; padding: 16px; max-height: 600px; overflow: auto;">
@Model.AnalysisJson
        </pre>
    </details>
}

@section Scripts {
<script>
(function () {
    var select = document.getElementById('movementSelect');
    var sport = document.getElementById('SportType');
    var movement = document.getElementById('MovementType');
    function sync() {
        var parts = (select.value || '|').split('|');
        sport.value = parts[0] || 'fitness';
        movement.value = parts[1] || 'squat';
    }
    select.addEventListener('change', sync);
    sync();

    var pendingFull = @(pendingFull ? "true" : "false");
    var analysisId = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AnalysisId ?? ""));
    var browserPlayable = @(Model.BrowserPlayableVideo ? "true" : "false");

    if (!pendingFull || !analysisId) {
        return;
    }

    var form = document.createElement('form');
    form.method = 'POST';
    form.action = '@Url.Action("CompareFull", "Pose")';
    var input = document.createElement('input');
    input.type = 'hidden';
    input.name = 'analysisId';
    input.value = analysisId;
    form.appendChild(input);

    var token = document.querySelector('input[name="__RequestVerificationToken"]');
    // antiforgery may be absent; endpoint accepts form post without token when not configured

    fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'analysisId=' + encodeURIComponent(analysisId)
    })
    .then(function (res) { return res.json().then(function (data) { return { ok: res.ok, data: data }; }); })
    .then(function (payload) {
        var pendingAlert = document.getElementById('comparePendingAlert');
        if (pendingAlert) {
            pendingAlert.style.display = 'none';
        }

        if (!payload.ok || payload.data.success === false) {
            var banner = document.getElementById('compareBanner');
            if (banner) {
                banner.innerHTML = '<div class="alert alert-danger">Full 對照分析失敗：'
                    + ((payload.data && payload.data.message) ? payload.data.message : '未知錯誤')
                    + '</div>';
                banner.style.display = '';
            }
            return;
        }

        var data = payload.data;
        var cmp = data.modelComparison || {};
        var summary = cmp.summary || {};
        var files = data.outputFiles || {};
        var cmpFiles = cmp.outputFiles || {};

        var pct = summary.overallDiffPercent;
        var pctText = document.getElementById('overallDiffPercentText');
        if (pctText) {
            pctText.textContent = (pct === null || pct === undefined) ? '—' : (Number(pct).toFixed(2) + '%');
        }
        var desc = document.getElementById('compareDescText');
        if (desc && cmp.metricDescription) {
            desc.textContent = cmp.metricDescription;
        }
        var resultAlert = document.getElementById('compareResultAlert');
        if (resultAlert) {
            resultAlert.style.display = '';
        }
        var banner = document.getElementById('compareBanner');
        if (banner) {
            banner.style.display = '';
        }

        var skUrl = cmpFiles.skeletonFullVideoUrl || files.skeletonFullVideoUrl;
        var trUrl = cmpFiles.trajectoryFullVideoUrl || files.trajectoryFullVideoUrl;

        var fullSection = document.getElementById('fullResultSection');
        if (fullSection) {
            fullSection.style.display = '';
        }

        function fillVideo(blockId, playerId, linkId, url) {
            if (!url) return;
            var block = document.getElementById(blockId);
            var link = document.getElementById(linkId);
            var player = document.getElementById(playerId);
            if (block) block.style.display = '';
            if (link) {
                link.href = url;
                link.style.display = '';
            }
            if (player && browserPlayable) {
                player.innerHTML = '<video controls playsinline style="max-width: 100%; background: #000;">'
                    + '<source src="' + url + '" type="video/mp4" /></video>';
            }
        }

        fillVideo('fullSkeletonBlock', 'fullSkeletonPlayer', 'fullSkeletonLink', skUrl);
        fillVideo('fullTrajectoryBlock', 'fullTrajectoryPlayer', 'fullTrajectoryLink', trUrl);

        var liteJson = files.rawLiteJsonUrl || cmpFiles.rawLiteJsonUrl || files.rawJsonUrl;
        var fullJson = files.rawFullJsonUrl || cmpFiles.rawFullJsonUrl;
        var liteLink = document.getElementById('rawLiteJsonLink');
        var fullLink = document.getElementById('rawFullJsonLink');
        var jsonButtons = document.getElementById('jsonDownloadButtons');
        if (jsonButtons && (liteJson || fullJson)) {
            jsonButtons.style.display = '';
        }
        if (liteLink && liteJson) {
            liteLink.href = liteJson;
            liteLink.style.display = '';
        }
        if (fullLink && fullJson) {
            fullLink.href = fullJson;
            fullLink.style.display = '';
        }
        var pre = document.getElementById('analysisJsonPre');
        if (pre) {
            pre.textContent = JSON.stringify(data, null, 2);
        }
    })
    .catch(function (err) {
        var banner = document.getElementById('compareBanner');
        if (banner) {
            banner.innerHTML = '<div class="alert alert-danger">Full 對照分析失敗：' + err + '</div>';
            banner.style.display = '';
        }
    });
})();
</script>
}
